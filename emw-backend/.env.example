# ═══════════════════════════════════════════════════════════════════════════════
# Iris Backend — variables de entorno (plantilla)
# Copia a .env.local o .env y rellena los valores reales desde Bitwarden/Vault.
# NUNCA hardcodees secretos en este archivo ni lo comitees con valores reales.
# ═══════════════════════════════════════════════════════════════════════════════

# Auth
AUTH_MODE=jwt
SESSION_SECRET=CHANGEME_SESSION_SECRET
BCRYPT_ROUNDS=10

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# Logging
LOG_LEVEL=info

# Security
API_KEY=CHANGEME_API_KEY
ENCRYPTION_KEY=CHANGEME_ENCRYPTION_KEY

# JWT
JWT_SECRET=CHANGEME_JWT_SECRET
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Database (Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=irisuser
DB_PASSWORD=CHANGEME_DB_PASSWORD
DB_DATABASE=iris
DB_SYNCHRONIZE=false

# WhatsApp API (Meta Cloud API)
WHATSAPP_API_BASE_URL=https://graph.facebook.com/v22.0
WHATSAPP_WEBHOOK_VERIFY_TOKEN=CHANGEME_WA_VERIFY_TOKEN

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_LAZY_CONNECT=true

# Server
NODE_ENV=production
HOST=0.0.0.0
PORT=3001

# URLs
APP_URL=https://iris-backend.example.com
FRONTEND_URL=https://iris.example.com
BACKEND_URL=https://iris-backend.example.com

# Prizma Hub (Nous) — integración inter-servicio
NOUS_HUB_URL=https://prizma-hub-kjopuery2a-uc.a.run.app
NOUS_HUB_SECRET=CHANGEME_NOUS_HUB_SECRET

# ─── Mercado Pago — cuenta CENTRAL Prizma (App "Prizma Suscripciones") ───────
# Obtener en: https://www.mercadopago.com.co/developers/panel
# Bloque A del documento PAYMENTS_MIGRATION.md
#
# Access token de producción (APP_USR-...) o test (TEST-...).
# El gateway de prizma-payments usa MP_ACCESS_TOKEN_TEST si MP_SANDBOX_MODE=true.
MP_ACCESS_TOKEN=CHANGEME_MP_ACCESS_TOKEN
#
# Clave pública (APP_USR-... / TEST-...) — solo para el frontend si se usa Bricks.
MP_PUBLIC_KEY=CHANGEME_MP_PUBLIC_KEY
#
# Secreto de firma de webhooks (x-signature). Se obtiene en la configuración
# de la aplicación MP bajo "Webhooks" → "Secreto". Registrar la URL:
#   https://prizma-hub-kjopuery2a-uc.a.run.app/webhooks/mercadopago
MP_WEBHOOK_SECRET=CHANGEME_MP_WEBHOOK_SECRET
#
# Activar modo sandbox (usa credenciales TEST-... en lugar de APP_USR-...)
MP_SANDBOX_MODE=false

# Cron secret (para el endpoint admin/check-expired)
CRON_SECRET=CHANGEME_CRON_SECRET

# Firebase (opcional — notificaciones push)
# FIREBASE_PROJECT_ID=
# FIREBASE_PRIVATE_KEY=
# FIREBASE_CLIENT_EMAIL=
