{
  "name": "prizma-payments",
  "version": "1.0.1",
  "description": "Abstracción de pagos de la suite Prizma sobre Mercado Pago (cuenta CENTRAL, Colombia/COP). Framework-agnóstica: la usan NestJS (Iris/Fiar) y Hapi.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean",
    "typecheck": "tsc --noEmit",
    "test": "node --test test/*.test.mjs"
  },
  "dependencies": {
    "mercadopago": "^2.12.0",
    "prizma-contracts": "^1.3.0"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "@types/node": "^20.14.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stevenvo780/prizma-payments.git"
  }
}
