# Node.js dependencies
node_modules/

# Build artifacts
dist/
*.tsbuildinfo

# olympo-payments-pkg ships its PREBUILT dist (1.0.1); the global dist/ rule
# above would strip it, so re-include the vendored package explicitly.
!olympo-payments-pkg/
!olympo-payments-pkg/dist/
!olympo-payments-pkg/dist/**

# Environment files
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Git
.git/
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Tests
tests/
*.test.ts
*.test.js
__tests__/

# Documentation
README.md
docs/

# Docker
.dockerignore

# Misc
.prettierrc
.eslintrc*
tsconfig.*.json
