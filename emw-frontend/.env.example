# ⚠️ CONFIGURACIÓN PARA PRODUCCIÓN - CONFIGURAR TODOS LOS VALORES
# Copiar a .env.local y configurar con valores reales

# ⚠️ CRÍTICO: URL del API backend (SIN TRAILING SLASH)
NEXT_PUBLIC_API_URL=https://your-api-domain.com/api

# ⚠️ CRÍTICO: URL del servicio WhatsApp (SIN TRAILING SLASH)
NEXT_PUBLIC_WPP_API=https://your-whatsapp-service-domain.com

# Configuración de la aplicación
NEXT_PUBLIC_APP_NAME=EMW - Enhanced Marketing WhatsApp
NEXT_PUBLIC_VERSION=2.0.0

# Entorno (⚠️ USAR 'production' EN PRODUCCIÓN)
NODE_ENV=production

# ⚠️ SEGURIDAD: Debug mode SIEMPRE false en producción
NEXT_PUBLIC_DEBUG_MODE=false

# Firebase Configuration (⚠️ CONFIGURAR CON VALORES REALES)
NEXT_PUBLIC_FIREBASE_API_KEY=your_real_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_real_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# Modo de desarrollo
NODE_ENV=development

#Variables usadas en desarrollo:

NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# WebSocket (para tiempo real)
NEXT_PUBLIC_WS_URL=ws://localhost:5000


# App Configuration
NEXT_PUBLIC_APP_VERSION=2.0.0
NEXT_PUBLIC_ENVIRONMENT=development

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_REAL_TIME=true

# Upload Configuration
NEXT_PUBLIC_MAX_FILE_SIZE=10485760  # 10MB
NEXT_PUBLIC_ALLOWED_FILE_TYPES=image/*,video/*,application/pdf